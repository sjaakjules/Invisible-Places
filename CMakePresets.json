{
  "version": 6,
  "cmakeMinimumRequired": {
    "major": 3,
    "minor": 30,
    "patch": 0
  },
  "configurePresets": [
    {
      "name": "macos-debug",
      "displayName": "macOS Debug",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build/macos-debug",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "INVISIBLE_PLACES_ENABLE_TESTS": "ON",
        "INVISIBLE_PLACES_ENABLE_VULKAN": "ON"
      }
    },
    {
      "name": "macos-debug-vcpkg",
      "displayName": "macOS Debug (vcpkg)",
      "inherits": "macos-debug",
      "toolchainFile": "$env{VCPKG_ROOT}/scripts/buildsystems/vcpkg.cmake",
      "cacheVariables": {
        "VCPKG_FEATURE_FLAGS": "manifests"
      }
    },
    {
      "name": "macos-debug-home-vcpkg",
      "displayName": "macOS Debug (home vcpkg clone)",
      "inherits": "macos-debug",
      "toolchainFile": "$penv{HOME}/vcpkg/scripts/buildsystems/vcpkg.cmake",
      "cacheVariables": {
        "VCPKG_FEATURE_FLAGS": "manifests"
      }
    },
    {
      "name": "windows-release-vcpkg",
      "displayName": "Windows Release (vcpkg)",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build/windows-release",
      "toolchainFile": "$env{VCPKG_ROOT}/scripts/buildsystems/vcpkg.cmake",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "VCPKG_FEATURE_FLAGS": "manifests",
        "INVISIBLE_PLACES_ENABLE_TESTS": "ON",
        "INVISIBLE_PLACES_ENABLE_VULKAN": "ON"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "build-macos-debug",
      "configurePreset": "macos-debug"
    },
    {
      "name": "build-macos-debug-vcpkg",
      "configurePreset": "macos-debug-vcpkg"
    },
    {
      "name": "build-macos-debug-home-vcpkg",
      "configurePreset": "macos-debug-home-vcpkg"
    },
    {
      "name": "build-windows-release-vcpkg",
      "configurePreset": "windows-release-vcpkg"
    }
  ]
}
